# StadiumMind AI - Backend (apps/api)
# The app runs fully in zero-config demo mode (in-memory store, deterministic AI,
# open routes). Each key below unlocks a real-data layer.

PORT=4000

# CORS origin for the web app
WEB_ORIGIN=http://localhost:3000

# Gemini (optional). Without a key, the API uses deterministic AI fallbacks.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Firebase Admin (optional). Path to a service-account JSON.
# Enables Firestore persistence + ID-token verification on admin/volunteer routes.
# NEVER commit the JSON file (gitignored). Seed with: npx tsx src/seed.ts
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Alternative to the file path above — used on hosts (Render/Railway/Fly) that
# don't let you drop an arbitrary file next to the app. Base64-encode the whole
# service-account JSON into this single var; it's decoded to a temp file at
# boot and GOOGLE_APPLICATION_CREDENTIALS is set automatically. Leave unset for
# local dev (the file path above is simpler there).
#   Windows:  [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase-service-account.json"))
#   macOS/Linux: base64 -i firebase-service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Sportmonks (optional). Real live-football feed: scores, minutes, lineups, events.
# Without it, the organizer's manual Live Score Controller is the only source.
SPORTMONKS_API_KEY=

# The real Sportmonks fixture is attached to ONE showcase match so every match
# doesn't display the same score. Defaults to the first match; override to pin
# the live feed to a specific match id.
LIVE_FEED_MATCH_ID=

# Live weather needs no key (Open-Meteo, queried at each stadium's coordinates).
